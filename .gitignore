# --- Environment & Secrets ---
.env
*.local
backend/.env
frontend/my-react-app/.env

# --- Python / Backend ---
# This ignores any 'venv' folder in the project
venv/
backend/venv/
.venv/
backend/__pycache__/
backend/*.pyc
backend/*.pyo
backend/*.pyd

# --- Node.js / Frontend ---
# This ignores 'node_modules' anywhere in the project
node_modules/
frontend/my-react-app/node_modules/
frontend/my-react-app/dist/
frontend/my-react-app/dist-ssr/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# --- Editor & System Files ---
.vscode/*
!.vscode/extensions.json
.idea/
.DS_Store
*.suo
*.sln
*.sw?

# --- Logs ---
logs
*.log